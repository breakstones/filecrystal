{
  "name": "filecrystal",
  "version": "0.3.0",
  "description": "Universal file parser for PDFs, images, xlsx/xls, docx — outputs Markdown and prompt-defined JSON via any OpenAI-compatible API.",
  "keywords": [
    "file-parser",
    "pdf",
    "xlsx",
    "docx",
    "markdown",
    "ocr",
    "llm",
    "openai-compatible",
    "qwen",
    "dashscope",
    "extract",
    "structure",
    "json-extraction"
  ],
  "license": "MIT",
  "author": "stone <stone.netclub@gmail.com>",
  "homepage": "https://github.com/breakstones/filecrystal#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/breakstones/filecrystal.git"
  },
  "bugs": {
    "url": "https://github.com/breakstones/filecrystal/issues"
  },
  "engines": {
    "node": ">=18.18"
  },
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./schema": {
      "import": {
        "types": "./dist/schema.d.ts",
        "default": "./dist/schema.js"
      },
      "require": {
        "types": "./dist/schema.d.cts",
        "default": "./dist/schema.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "filecrystal": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "vitest run -c vitest.e2e.config.ts",
    "cli": "tsx src/cli.ts",
    "prepublishOnly": "pnpm run build",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm run build && changeset publish"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.56",
    "commander": "^12.1.0",
    "gray-matter": "^4.0.3",
    "jszip": "^3.10.1",
    "mammoth": "^1.8.0",
    "mime-types": "^2.1.35",
    "openai": "^4.67.0",
    "p-limit": "^6.1.0",
    "pdfjs-dist": "^4.7.76",
    "sharp": "^0.33.5",
    "word-extractor": "^1.0.4",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.3"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^20.16.10",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "@vitest/coverage-v8": "^2.1.2",
    "docx": "^9.6.1",
    "eslint": "^9.12.0",
    "pdf-lib": "^1.17.1",
    "prettier": "^3.3.3",
    "tsup": "^8.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
